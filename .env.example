# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterprise_rag"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth (Optional - for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# AI Provider Keys (Can also be configured via UI Settings)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""

# Vector Database (Configure one)
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
PINECONE_API_KEY=""
PINECONE_INDEX=""
CHROMA_URL="http://localhost:8000"

# Redis (Optional - for caching)
REDIS_URL="redis://localhost:6379"

# Storage (Optional - defaults to local)
UPLOADTHING_TOKEN=""
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# LangSmith (Optional - for observability)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="enterprise-rag"

# Elasticsearch (Optional - for BM25/ES hybrid search)
ELASTICSEARCH_URL=""
ELASTICSEARCH_API_KEY=""

# Encryption Key for storing API keys in DB
ENCRYPTION_KEY="your-32-byte-encryption-key-here!"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
